# app-main local environment variables
# Copy this file to app-main/.env and fill local secrets.

# Database
SPRING_DATASOURCE_URL=jdbc:postgresql://localhost:5432/ieum
SPRING_DATASOURCE_USERNAME=
SPRING_DATASOURCE_PASSWORD=

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379

# SMTP
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=

# Auth
JWT_SECRET=
EMAIL_VERIFICATION_HMAC_SECRET=
JWT_ACCESS_TOKEN_TTL_MINUTES=30
JWT_REFRESH_TOKEN_TTL_DAYS=14
COOKIE_SECURE=true
COOKIE_SAME_SITE=Lax
COOKIE_DOMAIN=

# app-ai report review internal client (keep disabled until the worker rollout)
APP_AI_REPORT_ENABLED=false
APP_AI_REPORT_BASE_URL=
APP_AI_REPORT_ALLOWED_HOSTS=
APP_AI_REPORT_CONNECT_TIMEOUT_SECONDS=2
APP_AI_REPORT_READ_TIMEOUT_SECONDS=90

# app-ai question answer ticket wake (keep disabled until app-ai dispatch is ready)
APP_AI_QUESTION_ANSWER_DISPATCH_ENABLED=false
APP_AI_QUESTION_ANSWER_DISPATCH_BASE_URL=
APP_AI_QUESTION_ANSWER_DISPATCH_ALLOWED_HOSTS=
APP_AI_QUESTION_ANSWER_DISPATCH_CONNECT_TIMEOUT_SECONDS=2
APP_AI_QUESTION_ANSWER_DISPATCH_READ_TIMEOUT_SECONDS=5

# app-ai -> app-main completion callback (same value on both servers)
APP_AI_INTERNAL_CALLBACK_TOKEN=

# Place proxy (server-side only)
NAVER_SEARCH_CLIENT_ID=
NAVER_SEARCH_CLIENT_SECRET=
NCP_MAPS_KEY_ID=
NCP_MAPS_KEY=
